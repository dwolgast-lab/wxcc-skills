# wxcc-skills configuration — copy to `.env` and fill in. `.env` is gitignored.
# These come from the OAuth Integration you register at https://developer.webex.com
# (Manage Apps > Create an Integration). See the wxcc-connect skill for the walkthrough.

# --- Required: OAuth Integration credentials ---
WXCC_CLIENT_ID=
WXCC_CLIENT_SECRET=

# Redirect URI — must EXACTLY match one registered on the integration.
# The helper starts a local listener on this URI's host/port to catch the auth code.
WXCC_REDIRECT_URI=http://localhost:8484/callback

# Space-separated OAuth scopes. Start read-only; add cjp:config for write skills later.
# The authorizing user must be a Webex Contact Center administrator.
WXCC_SCOPES=cjp:config_read

# --- Required: runtime API host for YOUR tenant's region ---
# Confirmed host for the US region is api.wxcc-us1.cisco.com. Set to your region's host.
WXCC_API_BASE=https://api.wxcc-us1.cisco.com

# --- Optional ---
# Org ID is auto-derived from the access token. Uncomment to override if calls 404 on org.
# WXCC_ORG_ID=
